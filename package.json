{
  "name": "spotify-karaoke",
  "version": "3.0.5",
  "description": "WXT browser extension for Chrome/Firefox — romanizes and translates Spotify lyrics in real time",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build:romanizer": "npm run build --workspace @spotify-karaoke/romanizer",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "prepare": "npm run build:romanizer && wxt prepare",
    "prebuild": "npm run build:romanizer",
    "prebuild:firefox": "npm run build:romanizer",
    "prebuild:edge": "npm run build:romanizer",
    "prezip": "npm run build:romanizer",
    "prezip:firefox": "npm run build:romanizer",
    "prezip:edge": "npm run build:romanizer",
    "pretest": "npm run build:romanizer",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@spotify-karaoke/romanizer": "workspace:*",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.2",
    "@testing-library/preact": "^3.2.4",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.3",
    "vite-plugin-string-replace": "^1.1.5",
    "vitest": "^4.0.18",
    "wxt": "^0.20.5"
  }
}
