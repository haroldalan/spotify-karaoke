{
  "name": "spotify-karaoke",
  "version": "3.1.0",
  "description": "WXT browser extension for Chrome/Firefox — fetches missing lyrics, restores native scripts, and romanizes & translates Spotify lyrics in real time",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "prepare": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dehoist/romanize-thai": "^1.0.0",
    "@indic-transliteration/sanscript": "^1.3.3",
    "@romanize/korean": "^0.1.3",
    "@sglkc/kuroshiro": "^1.0.1",
    "@sglkc/kuroshiro-analyzer-kuromoji": "^1.0.1",
    "cyrillic-to-translit-js": "^3.2.1",
    "pinyin-pro": "^3.28.0",
    "preact": "^10.25.4",
    "tamil-romanizer": "^1.0.2",
    "transliteration": "^2.3.5"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.2",
    "@testing-library/preact": "^3.2.4",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.3",
    "vite-plugin-string-replace": "^1.1.5",
    "vitest": "^4.0.18",
    "wxt": "^0.20.5"
  }
}