{
  "name": "@spotify-karaoke/romanizer",
  "version": "0.1.0",
  "description": "Script detection and local romanization engine used by Spotify Karaoke",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./detector": {
      "types": "./src/detector.ts",
      "import": "./dist/detector.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dehoist/romanize-thai": "^1.0.0",
    "@indic-transliteration/sanscript": "^1.3.3",
    "@romanize/korean": "^0.1.3",
    "@sglkc/kuroshiro": "^1.0.1",
    "@sglkc/kuroshiro-analyzer-kuromoji": "^1.0.1",
    "cyrillic-to-translit-js": "^3.2.1",
    "pinyin-pro": "^3.28.0",
    "tamil-romanizer": "^1.0.2"
  }
}
